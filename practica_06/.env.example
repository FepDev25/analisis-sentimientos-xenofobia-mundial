# Bluesky 

BLUESKY_HANDLE=tu_usuario.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# TikTok
# Copiarlo desde las cookies de tiktok.com. TikTokApi usa este token para crear
# una sesión de navegador con Playwright.
TIKTOK_MS_TOKEN=
TIKTOK_BROWSER=chromium
TIKTOK_HEADLESS=true
TIKTOK_PROFILE_DIR=.playwright/tiktok-profile
TIKTOK_COOKIES_FILE=.playwright/tiktok-cookies.json
TIKTOK_TIMEOUT_MS=90000
TIKTOK_MODE=api

# Reddit:  descartado (13-jul-2026). Responde 403 al acceso programático desde su propia CDN y su registro de apps ya no emite credenciales.

# Tumblr
# OAuth Consumer Key de la aplicación registrada en Tumblr.
TUMBLR_API_KEY=

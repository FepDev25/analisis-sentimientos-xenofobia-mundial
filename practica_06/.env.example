# Bluesky 

BLUESKY_HANDLE=tu_usuario.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# TikTok
# Copiarlo desde las cookies de tiktok.com. TikTokApi usa este token para crear
# una sesión de navegador con Playwright.
TIKTOK_MS_TOKEN=
TIKTOK_BROWSER=chromium

